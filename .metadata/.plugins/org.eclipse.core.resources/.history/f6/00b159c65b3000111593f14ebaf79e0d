package com.syed.fds.service;

import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

import org.springframework.security.core.context.SecurityContextHolder;
import org.springframework.stereotype.Service;

import com.syed.fds.dto.request.CreateRecordRequest;
import com.syed.fds.dto.request.UpdateRecordRequest;
import com.syed.fds.dto.response.RecordResponse;
import com.syed.fds.entity.FinancialRecord;
import com.syed.fds.entity.User;
import com.syed.fds.enums.TransactionType;
import com.syed.fds.exception.ResourceNotFoundException;
import com.syed.fds.repository.FinancialRecordRepository;
import com.syed.fds.repository.UserRepository;

@Service
public class FinancialRecordService {
	
	private final FinancialRecordRepository financialRecordRepository;
	private final UserRepository userRepository;
	
	public FinancialRecordService(FinancialRecordRepository financialRecordRepository, UserRepository userRepository) {
		this.financialRecordRepository = financialRecordRepository;
		this.userRepository = userRepository;
	}
	
	public List<RecordResponse> getAllRecords() {
		
		List<FinancialRecord> records = financialRecordRepository
											.findWithFilters(
												TransactionType type,
												TransactionCategory category,
												LocalDate from, 
												LocalDate to
											);
		List<RecordResponse> responseBody = records.stream()
												.map((record) -> mapToResponse(record))
												.collect(Collectors.toList());
		return responseBody; 
	}
	
	public RecordResponse getRecordById(Long id) {
		
		FinancialRecord record = financialRecordRepository.findById(id)
				.orElseThrow(() -> new ResourceNotFoundException("Record not found with id: " + id));
		return mapToResponse(record);
	}
	
	private RecordResponse mapToResponse(FinancialRecord record) {
		RecordResponse response = new RecordResponse();
		response.setId(record.getId());
		response.setAmount(record.getAmount());
		response.setCreatedBy(record.getCreatedBy().getUsername());
		response.setType(record.getType());
		response.setCategory(record.getCategory());
		response.setCreatedAt(record.getCreatedAt());
		response.setDescription(record.getDescription());
		return response;
	}
	
	public Map<String, Object> createRecord(CreateRecordRequest recordRequest) {
		
		String username = SecurityContextHolder.getContext().getAuthentication().getName();
		User user = userRepository.findByUsername(username)
				.orElseThrow(() -> new ResourceNotFoundException("User not found"));
		
		FinancialRecord record = new FinancialRecord();
		record.setAmount(recordRequest.getAmount());
		record.setCreatedBy(user);
		record.setCategory(recordRequest.getCategory());
		record.setType(recordRequest.getType());
		record.setDescription(recordRequest.getDescription());
		financialRecordRepository.save(record);
		
		return Map.of("message", " Record created successfully", "Transaction Record Id", record.getId(), "Transaction Amount", record.getAmount());
		
	}
	
	public Map<String, Object> updateRecord(Long id, UpdateRecordRequest updateRequest) {
		
		FinancialRecord record = financialRecordRepository.findById(id)
				.orElseThrow(() -> new ResourceNotFoundException("Record not found with id: " + id));
		
		record.setAmount(updateRequest.getAmount()!= null ? updateRequest.getAmount() : record.getAmount());
		record.setType(updateRequest.getType()!= null ? updateRequest.getType() : record.getType());
		record.setCategory(updateRequest.getCategory()!= null ? updateRequest.getCategory() : record.getCategory());
		record.setDescription(updateRequest.getDescription()!= null ? updateRequest.getDescription() : record.getDescription());
		financialRecordRepository.save(record);
		
		return Map.of("message", "Record updated successfully!!", "recordId", id);
		
	}
	
	public Map<String, Object> deleteRecord(Long id) {
		
		FinancialRecord record = financialRecordRepository.findById(id)
				.orElseThrow(() -> new ResourceNotFoundException("Record not found with id: " + id));
		
		financialRecordRepository.delete(record);
		
		return Map.of("message", "Record deleted successfully with id :" + id);
		
	}
	

}
