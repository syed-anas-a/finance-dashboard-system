package com.syed.fds.service;

import java.math.BigDecimal;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.HashSet;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.Set;
import java.util.stream.Collectors;

import org.springframework.stereotype.Service;

import com.syed.fds.dto.response.DashboardSummaryResponse;
import com.syed.fds.entity.FinancialRecord;
import com.syed.fds.enums.TransactionType;
import com.syed.fds.repository.FinancialRecordRepository;

@Service
public class DashboardService {
	
	private final FinancialRecordRepository financialRecordRepository;
	
	public DashboardService(FinancialRecordRepository financialRecordRepository) {
		this.financialRecordRepository = financialRecordRepository;
	}	
	
	private static final String[] MONTH_NAMES = {
		    "", "January", "February", "March", "April",
		    "May", "June", "July", "August", "September",
		    "October", "November", "December"
		};

	public DashboardSummaryResponse getDashboardSummary() {

	    BigDecimal totalIncome = financialRecordRepository.sumByType(TransactionType.INCOME);
	    BigDecimal totalExpense = financialRecordRepository.sumByType(TransactionType.EXPENSE);
	    totalIncome = totalIncome != null ? totalIncome : BigDecimal.ZERO;
	    totalExpense = totalExpense != null ? totalExpense : BigDecimal.ZERO;
	    BigDecimal netBalance = totalIncome.subtract(totalExpense);

	    List<Map<String, Object>> categoryBreakdown = financialRecordRepository
	        .sumByCategory()
	        .stream()
	        .map(row -> {
	            Map<String, Object> map = new LinkedHashMap<>();
	            map.put("category", row[0].toString());
	            map.put("total", row[1]);
	            return map;
	        })
	        .collect(Collectors.toList());

	    List<Object[]> incomeRows = financialRecordRepository
	    	    .sumByMonthAndType(TransactionType.INCOME);
	    	List<Object[]> expenseRows = financialRecordRepository
	    	    .sumByMonthAndType(TransactionType.EXPENSE);

	    	// income map — month number → amount
	    	Map<Integer, BigDecimal> incomeMap = incomeRows.stream()
	    	    .collect(Collectors.toMap(
	    	        row -> ((Number) row[0]).intValue(),
	    	        row -> (BigDecimal) row[1]
	    	    ));

	    	// expense map — month number → amount
	    	Map<Integer, BigDecimal> expenseMap = expenseRows.stream()
	    	    .collect(Collectors.toMap(
	    	        row -> ((Number) row[0]).intValue(),
	    	        row -> (BigDecimal) row[1]
	    	    ));

	    	// combine both maps
	    	Set<Integer> allMonths = new HashSet()<>();
	    	allMonths.addAll(incomeMap.keySet());
	    	allMonths.addAll(expenseMap.keySet());

	    	List<Map<String, Object>> monthlyTrends = allMonths.stream()
	    	    .sorted()
	    	    .map(month -> {
	    	        Map<String, Object> map = new LinkedHashMap<>();
	    	        map.put("month", MONTH_NAMES[month]);
	    	        map.put("totalIncome", incomeMap.getOrDefault(month, BigDecimal.ZERO));
	    	        map.put("totalExpense", expenseMap.getOrDefault(month, BigDecimal.ZERO));
	    	        return map;
	    	    })
	    	    .collect(Collectors.toList());
	

	    List<Map<String, Object>> recentActivity = financialRecordRepository
	        .findTop10ByOrderByDateDesc()
	        .stream()
	        .map(record -> {
	            Map<String, Object> map = new LinkedHashMap<>();
	            map.put("id", record.getId());
	            map.put("amount", record.getAmount());
	            map.put("type", record.getType());
	            map.put("category", record.getCategory());
	            map.put("date", record.getDate());
	            map.put("description", record.getDescription());
	            return map;
	        })
	        .collect(Collectors.toList());

	    DashboardSummaryResponse response = new DashboardSummaryResponse();
	    response.setTotalIncome(totalIncome);
	    response.setTotalExpense(totalExpense);
	    response.setNetBalance(netBalance);
	    response.setCategoryBreakdown(categoryBreakdown);
	    response.setMonthlyTrends(monthlyTrends);
	    response.setRecentActivity(recentActivity);

	    return response;
	}

}
