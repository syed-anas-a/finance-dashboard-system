	public Map<String, Object> getDashboardSummary() {
		
		BigDecimal totalIncome = financialRecordRepository.sumByType(TransactionType.INCOME);
		BigDecimal totalExpense = financialRecordRepository.sumByType(TransactionType.EXPENSE);
		BigDecimal netBalance = totalIncome.subtract(totalExpense);
		List<Object[]> sumByCategory = financialRecordRepository.sumByCategory();
		List<FinancialRecord> recentActivity = financialRecordRepository.findTop10ByOrderByDateDesc();
		
		Map<String, Object> responseBody = mapToResponse(totalIncome, totalExpense, netBalance, sumByCategory, recentActivity);
		
		
